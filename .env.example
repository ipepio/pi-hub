# ========= pihub =========

# Token compartido para API, panel y UIs de agente (¡cámbialo!)
API_TOKEN=cambia-este-token

# Puertos
PIHUB_MANAGER_PORT=4000
PIHUB_AGENT_PORT_RANGE=4100-4199

# Panel web del manager (true/false)
PIHUB_PANEL_ENABLED=true

# Stack inicial de paquetes globales (coma-separados), instalados al arrancar si faltan.
# Formatos: npm:@scope/pkg[@version] · git:github.com/user/repo[@ref] · /ruta/local
PIHUB_GLOBAL_PACKAGES=

# Modelo por defecto para agentes nuevos (proveedor/id)
PIHUB_DEFAULT_MODEL=anthropic/claude-sonnet-5

# Si true, el models.json del repo sobrescribe el del volumen en cada arranque.
# models.json no está en git (puede contener datos sensibles); créalo antes de arrancar:
#   cp models.example.json models.json && vim models.json
PIHUB_OVERWRITE_MODELS=false

# Memoria persistente (extensión pihub-memory + inyección en system prompt)
PIHUB_MEMORY_ENABLED=true

# Acceso por defecto de los agentes a la Shared Memory (la memoria compartida del
# runtime, antes llamada "global"). Cada agente puede tener su propio override con
# memory.sharedAccess (API, manifiesto o `pihub agent update --shared-memory`).
# Valores: none | read | read-write. Con none cada agente solo ve su memoria privada.
# Cambiar este default solo afecta a runners que arranquen después (reinicia con
# `pihub agent restart` o reiniciando el manager).
PIHUB_SHARED_MEMORY_DEFAULT=none

# Conciencia de plataforma: inyecta en el system prompt qué es pihub, dónde se
# ejecuta el agente y qué puede hacer (independiente de la persona de SYSTEM.md)
PIHUB_PLATFORM_PROMPT_ENABLED=true

# OAuth de suscripción: proveedores permitidos, coma-separados. Vacío = desactivado.
# Valores típicos: anthropic (Claude Pro/Max), openai (ChatGPT Plus/Pro vía Codex)
PIHUB_OAUTH_PROVIDERS=

# Telegram: ids de usuario permitidos (coma-separados). Vacío = cualquiera (¡cuidado!)
PIHUB_TELEGRAM_ALLOWED_USERS=

# Provisión declarativa: ruta a un manifiesto JSON de agentes que se crea/actualiza
# al arrancar (ver agents.example.json). Idempotente: nunca borra agentes ni resetea
# campos ausentes. Los valores soportan ${VAR} para no escribir secretos en el archivo.
PIHUB_AGENTS_FILE=

# ========= Voz (STT/TTS) =========
# Servidor de audio OpenAI-compatible (speaches, LocalAI...) con
# /v1/audio/transcriptions (whisper) y /v1/audio/speech (kokoro).
# Vacío = voz desactivada (el mic no aparece y Telegram no acepta audios).
PIHUB_SPEECH_URL=
PIHUB_SPEECH_API_KEY=
# Modelo de transcripción (STT), p.ej. Systran/faster-whisper-small o whisper-1
PIHUB_STT_MODEL=
# Modelo de síntesis (TTS), p.ej. kokoro. Si está definido, en Telegram el agente
# responde a los audios también con nota de voz.
PIHUB_TTS_MODEL=
# Voz por defecto de la plataforma (cada agente puede tener la suya: ttsVoice)
PIHUB_TTS_VOICE=

# Retención de archivos subidos desde el chat al workspace del agente (horas).
# Pasado ese tiempo se borran automáticamente. Default: 24
PIHUB_UPLOADS_RETENTION_HOURS=

# ========= API keys de proveedores (las que uses) =========
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Proveedores custom: models.json no está en git. Para añadir uno,
# cp models.example.json models.json, edits the file, and define aquí su API key.
# Ejemplo incluido: proveedor "NaN" (usa $NAN_API_KEY).
NAN_API_KEY=
